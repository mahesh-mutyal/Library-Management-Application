<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-lg border-0 rounded-4">
      <div class="card-body p-5">
        <div class="text-center mb-4">
          <div class="display-4 text-primary"><i class="bi bi-book-half"></i></div>
          <h2 class="fw-bold mt-2"><%= t('appName') %></h2>
          <p class="text-muted"><%= t('auth.login') %></p>
        </div>

        <form action="/login" method="POST">
          <div class="mb-3">
            <label class="form-label fw-semibold"><i class="bi bi-envelope me-1"></i><%= t('auth.email') %></label>
            <input type="email" name="email" class="form-control form-control-lg" required
                   placeholder="admin@library.com" />
          </div>
          <div class="mb-4">
            <label class="form-label fw-semibold"><i class="bi bi-lock me-1"></i><%= t('auth.password') %></label>
            <div class="input-group">
              <input type="password" name="password" id="passwordInput" class="form-control form-control-lg" required />
              <button type="button" class="btn btn-outline-secondary" onclick="togglePassword()">
                <i class="bi bi-eye" id="eyeIcon"></i>
              </button>
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-lg w-100 fw-semibold">
            <i class="bi bi-box-arrow-in-right me-2"></i><%= t('auth.loginBtn') %>
          </button>
        </form>

        <div class="mt-4 p-3 bg-light rounded-3 small">
          <strong>Demo Credentials:</strong><br/>
          Admin: admin@library.com / Admin@123<br/>
          Employee: ravi@library.com / Emp@123
        </div>

        <!-- Language selector -->
        <div class="text-center mt-3">
          <a href="?lang=en" class="btn btn-sm btn-outline-secondary me-1">English</a>
          <a href="?lang=mr" class="btn btn-sm btn-outline-secondary">मराठी</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function togglePassword() {
  const input = document.getElementById('passwordInput');
  const icon = document.getElementById('eyeIcon');
  if (input.type === 'password') {
    input.type = 'text';
    icon.className = 'bi bi-eye-slash';
  } else {
    input.type = 'password';
    icon.className = 'bi bi-eye';
  }
}
</script>
