<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-arrow-left-right me-2 text-warning"></i><%= t('transactions.title') %></h2>
  <div class="d-flex gap-2">
    <a href="/transactions/checkout" class="btn btn-primary"><i class="bi bi-box-arrow-right me-1"></i>Checkout</a>
    <a href="/transactions/checkin" class="btn btn-success"><i class="bi bi-box-arrow-in-left me-1"></i>Check-in</a>
  </div>
</div>

<!-- Filter -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body py-2">
    <form class="d-flex gap-2 align-items-center" method="GET">
      <label class="fw-semibold me-2">Status:</label>
      <% [['', 'All'], ['active', 'Active'], ['overdue', 'Overdue'], ['returned', 'Returned']].forEach(([val, label]) => { %>
        <a href="?status=<%= val %>" class="btn btn-sm <%= query.status === val ? 'btn-primary' : 'btn-outline-secondary' %>">
          <%= label %>
        </a>
      <% }) %>
    </form>
  </div>
</div>

<p class="text-muted small mb-3"><%= pagination.total %> transactions</p>

<% if (!transactions.length) { %>
<div class="text-center py-5 text-muted">
  <i class="bi bi-inbox display-4"></i>
  <p class="mt-2">No transactions found.</p>
</div>
<% } else { %>
<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Book</th>
          <th>Customer</th>
          <th>Checkout</th>
          <th>Due Date</th>
          <th>Return Date</th>
          <th>Status</th>
          <th>Fine</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% transactions.forEach(tx => { %>
        <tr>
          <td>
            <div class="fw-semibold small"><%= tx.book?.title %></div>
            <code class="small"><%= tx.book?.bookNumber %></code>
          </td>
          <td>
            <div class="fw-semibold small"><%= tx.customer?.name %></div>
            <small class="text-muted"><%= tx.customer?.mobile %></small>
          </td>
          <td class="small"><%= moment(tx.checkoutDate).format('DD MMM YY') %></td>
          <td class="small <%= tx.status === 'overdue' ? 'text-danger fw-bold' : '' %>">
            <%= moment(tx.dueDate).format('DD MMM YY') %>
          </td>
          <td class="small"><%= tx.checkinDate ? moment(tx.checkinDate).format('DD MMM YY') : '—' %></td>
          <td>
            <span class="badge bg-<%= tx.status === 'returned' ? 'success' : tx.status === 'overdue' ? 'danger' : 'warning' %>">
              <%= tx.status %>
            </span>
          </td>
          <td>
            <% if (tx.fineAmount > 0) { %>
            <span class="badge bg-<%= tx.fineStatus === 'paid' ? 'secondary' : 'danger' %>">
              ₹<%= tx.fineAmount %>
            </span>
            <% } else { %>
            <span class="text-muted small">—</span>
            <% } %>
          </td>
          <td>
            <a href="/transactions/<%= tx._id %>" class="btn btn-sm btn-outline-primary">
              <i class="bi bi-eye"></i>
            </a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (pagination.totalPages > 1) { %>
<nav class="mt-3">
  <ul class="pagination justify-content-center">
    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>&status=<%= query.status||'' %>"><%= i %></a>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>
<% } %>
