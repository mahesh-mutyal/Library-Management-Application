<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | <%= appName %></title>

  <!-- Bootstrap 5 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />
  <!-- Noto Sans Devanagari (Marathi support) + Poppins -->
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@400;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="<%= currentLang === 'mr' ? 'lang-mr' : '' %>">

<!-- ── Navbar ──────────────────────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" href="/dashboard">
      <i class="bi bi-book-half me-2"></i><%= t('appName') %>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMain">
      <% if (currentUser) { %>
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2 me-1"></i><%= t('nav.dashboard') %></a>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
            <i class="bi bi-book me-1"></i><%= t('nav.books') %>
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/books"><i class="bi bi-list me-2"></i><%= t('nav.books') %></a></li>
            <li><a class="dropdown-item" href="/books/add"><i class="bi bi-plus-circle me-2"></i><%= t('nav.addBook') %></a></li>
          </ul>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
            <i class="bi bi-people me-1"></i><%= t('nav.customers') %>
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/customers"><i class="bi bi-list me-2"></i><%= t('nav.customers') %></a></li>
            <li><a class="dropdown-item" href="/customers/add"><i class="bi bi-person-plus me-2"></i><%= t('nav.addCustomer') %></a></li>
          </ul>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
            <i class="bi bi-arrow-left-right me-1"></i><%= t('nav.transactions') %>
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/transactions"><i class="bi bi-list me-2"></i><%= t('nav.transactions') %></a></li>
            <li><a class="dropdown-item" href="/transactions/checkout"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.checkout') %></a></li>
            <li><a class="dropdown-item" href="/transactions/checkin"><i class="bi bi-box-arrow-in-left me-2"></i><%= t('nav.checkin') %></a></li>
          </ul>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/reports"><i class="bi bi-bar-chart me-1"></i><%= t('nav.reports') %></a>
        </li>
      </ul>
      <% } %>

      <div class="d-flex align-items-center gap-2">
        <!-- Language Toggle -->
        <div class="dropdown">
          <button class="btn btn-outline-light btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
            <i class="bi bi-translate me-1"></i>
            <%= currentLang === 'mr' ? 'मराठी' : 'English' %>
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item <%= currentLang === 'en' ? 'active' : '' %>" href="?lang=en">English</a></li>
            <li><a class="dropdown-item <%= currentLang === 'mr' ? 'active' : '' %>" href="?lang=mr">मराठी</a></li>
          </ul>
        </div>

        <% if (currentUser) { %>
        <div class="dropdown">
          <button class="btn btn-outline-light btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
            <i class="bi bi-person-circle me-1"></i><%= currentUser.name %>
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><span class="dropdown-item-text text-muted small"><%= currentUser.role %></span></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i><%= t('nav.logout') %></a></li>
          </ul>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<!-- ── Flash Messages ──────────────────────────────────────────────────────── -->
<div class="container-fluid mt-2">
  <% if (success && success.length) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle me-2"></i><%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-circle me-2"></i><%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
</div>

<!-- ── Main Content ────────────────────────────────────────────────────────── -->
<main class="container-fluid py-3">
  <%- body %>
</main>

<footer class="text-center text-muted py-3 border-top small mt-4">
  <%= t('appName') %> &copy; <%= new Date().getFullYear() %>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<!-- Custom JS -->
<script src="/js/main.js"></script>
</body>
</html>
