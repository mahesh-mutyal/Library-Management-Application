<div class="d-flex align-items-center mb-4">
  <a href="/books/<%= book._id %>" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
  <h2 class="fw-bold mb-0"><i class="bi bi-qr-code me-2"></i>QR Code – <%= book.title %></h2>
</div>

<div class="row justify-content-center">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm text-center" id="qrCard">
      <div class="card-body p-4">
        <div class="fw-bold text-uppercase text-muted small mb-2">Library Management System</div>
        <img src="<%= book.qrCode %>" alt="QR Code" class="img-fluid mb-3" style="max-width:250px;" />
        <h5 class="fw-bold"><%= book.title %></h5>
        <p class="text-muted mb-1"><%= book.author %></p>
        <code class="fs-5"><%= book.bookNumber %></code>
        <div class="mt-3">
          <span class="badge bg-light text-dark border">Scan to checkout / checkin</span>
        </div>
      </div>
    </div>
    <div class="text-center mt-3 d-print-none">
      <button onclick="window.print()" class="btn btn-dark me-2">
        <i class="bi bi-printer me-1"></i>Print QR
      </button>
      <a href="/books/<%= book._id %>" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Book
      </a>
    </div>
  </div>
</div>

<style>
@media print {
  nav, footer, .d-print-none { display: none !important; }
  #qrCard { border: 2px solid #000 !important; }
}
</style>
