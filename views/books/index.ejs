<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-book me-2 text-primary"></i><%= t('books.title') %></h2>
  <div class="d-flex gap-2">
    <a href="/books/add" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i><%= t('books.addBook') %></a>
    <button class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#importModal">
      <i class="bi bi-file-earmark-excel me-1"></i><%= t('books.importExcel') %>
    </button>
  </div>
</div>

<!-- Search & Filter -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form class="row g-2" method="GET" action="/books">
      <div class="col-md-6">
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input type="text" name="q" class="form-control" placeholder="<%= t('books.searchPlaceholder') %>"
                 value="<%= query.q || '' %>" />
        </div>
      </div>
      <div class="col-md-3">
        <select name="category" class="form-select">
          <option value=""><%= t('common.all') %> Categories</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= query.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <select name="status" class="form-select">
          <option value=""><%= t('common.all') %> Status</option>
          <option value="available" <%= query.status === 'available' ? 'selected' : '' %>><%= t('books.available') %></option>
          <option value="checked_out" <%= query.status === 'checked_out' ? 'selected' : '' %>><%= t('books.checkedOut') %></option>
        </select>
      </div>
      <div class="col-md-1">
        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
      </div>
    </form>
  </div>
</div>

<!-- Stats bar -->
<p class="text-muted small mb-3">Showing <%= books.length %> of <%= pagination.total %> books</p>

<!-- Books Grid -->
<% if (books.length === 0) { %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-book-x display-4"></i>
    <p class="mt-2"><%= t('books.noBooks') %></p>
  </div>
<% } else { %>
<div class="row g-3 mb-4">
  <% books.forEach(book => { %>
  <div class="col-6 col-md-4 col-lg-3 col-xl-2">
    <div class="card h-100 border-0 shadow-sm book-card">
      <div class="book-cover-wrap">
        <% if (book.image) { %>
          <img src="<%= book.image %>" class="card-img-top book-cover" alt="<%= book.title %>" />
        <% } else { %>
          <div class="book-cover-placeholder">
            <i class="bi bi-book display-5 text-secondary"></i>
          </div>
        <% } %>
        <span class="badge bg-<%= book.status === 'available' ? 'success' : book.status === 'checked_out' ? 'warning' : 'secondary' %> book-status-badge">
          <%= book.availableCopies %>/<%= book.totalCopies %>
        </span>
      </div>
      <div class="card-body p-2">
        <h6 class="card-title fw-semibold mb-0 text-truncate" title="<%= book.title %>"><%= book.title %></h6>
        <p class="text-muted small mb-1 text-truncate"><%= book.author %></p>
        <span class="badge bg-light text-dark border small"><%= book.category %></span>
      </div>
      <div class="card-footer bg-white border-0 p-2 d-flex gap-1">
        <a href="/books/<%= book._id %>" class="btn btn-sm btn-outline-primary flex-grow-1">
          <i class="bi bi-eye"></i>
        </a>
        <a href="/books/<%= book._id %>/edit" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-pencil"></i>
        </a>
        <a href="/books/<%= book._id %>/qr" class="btn btn-sm btn-outline-dark">
          <i class="bi bi-qr-code"></i>
        </a>
      </div>
    </div>
  </div>
  <% }) %>
</div>

<!-- Pagination -->
<% if (pagination.totalPages > 1) { %>
<nav>
  <ul class="pagination justify-content-center">
    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>&q=<%= query.q||'' %>&category=<%= query.category||'' %>&status=<%= query.status||'' %>"><%= i %></a>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>
<% } %>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-file-earmark-excel me-2"></i>Import Books from Excel</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <a href="/api/template/books" class="btn btn-sm btn-outline-success mb-3">
          <i class="bi bi-download me-1"></i><%= t('common.downloadTemplate') %>
        </a>
        <form action="/books/import" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">Select Excel File (.xlsx)</label>
            <input type="file" name="excelFile" class="form-control" accept=".xlsx,.xls" required />
          </div>
          <button type="submit" class="btn btn-success w-100">
            <i class="bi bi-upload me-1"></i>Import
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
