<div class="d-flex align-items-center mb-4">
  <a href="/books/<%= book._id %>" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
  <h2 class="fw-bold mb-0"><i class="bi bi-pencil me-2 text-warning"></i>Edit Book</h2>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <form action="/books/<%= book._id %>?_method=PUT" method="POST" enctype="multipart/form-data">
      <div class="row g-3">
        <div class="col-md-8">
          <label class="form-label fw-semibold"><%= t('books.bookTitle') %> *</label>
          <input type="text" name="title" class="form-control" required value="<%= book.title %>" />
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold"><%= t('books.bookNumber') %></label>
          <input type="text" class="form-control" value="<%= book.bookNumber %>" readonly disabled />
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold"><%= t('books.author') %> *</label>
          <input type="text" name="author" class="form-control" required value="<%= book.author %>" />
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold"><%= t('books.category') %></label>
          <select name="category" class="form-select">
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= book.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold">Copies</label>
          <input type="number" name="totalCopies" class="form-control" value="<%= book.totalCopies %>" min="1" />
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold"><%= t('books.isbn') %></label>
          <input type="text" name="isbn" class="form-control" value="<%= book.isbn || '' %>" />
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold"><%= t('books.publisher') %></label>
          <input type="text" name="publisher" class="form-control" value="<%= book.publisher || '' %>" />
        </div>
        <div class="col-md-2">
          <label class="form-label fw-semibold">Year</label>
          <input type="number" name="publishYear" class="form-control" value="<%= book.publishYear || '' %>" />
        </div>
        <div class="col-md-2">
          <label class="form-label fw-semibold">Language</label>
          <select name="language" class="form-select">
            <% ['English','Marathi','Hindi','Sanskrit','Other'].forEach(l => { %>
              <option value="<%= l %>" <%= book.language === l ? 'selected' : '' %>><%= l %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label fw-semibold"><%= t('books.description') %></label>
          <textarea name="description" class="form-control" rows="3"><%= book.description || '' %></textarea>
        </div>
        <div class="col-12">
          <label class="form-label fw-semibold">Tags</label>
          <input type="text" name="tags" class="form-control" value="<%= (book.tags||[]).join(', ') %>" />
        </div>
        <div class="col-12">
          <label class="form-label fw-semibold">Replace Cover Image</label>
          <% if (book.image) { %>
            <div class="mb-2"><img src="<%= book.image %>" style="height:80px;object-fit:cover;" class="rounded" /></div>
          <% } %>
          <input type="file" name="image" class="form-control" accept="image/*" />
        </div>
      </div>

      <hr class="my-4" />
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0"><i class="bi bi-sliders me-2"></i>Custom Fields</h6>
        <button type="button" class="btn btn-sm btn-outline-primary" onclick="addCustomField()">
          <i class="bi bi-plus me-1"></i>Add Field
        </button>
      </div>
      <div id="customFieldsContainer">
        <% (book.customFields || []).forEach((f, i) => { %>
        <div class="row g-2 mb-2 custom-field-row">
          <div class="col-5"><input type="text" class="form-control form-control-sm cf-name" value="<%= f.fieldName %>" placeholder="Field Name" /></div>
          <div class="col-3">
            <select class="form-select form-select-sm cf-type">
              <% ['text','number','date','boolean'].forEach(t => { %>
                <option value="<%= t %>" <%= f.fieldType === t ? 'selected' : '' %>><%= t %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-3"><input type="text" class="form-control form-control-sm cf-value" value="<%= f.fieldValue || '' %>" placeholder="Value" /></div>
          <div class="col-1"><button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('.custom-field-row').remove()"><i class="bi bi-trash"></i></button></div>
        </div>
        <% }) %>
      </div>
      <input type="hidden" name="customFieldsJson" id="customFieldsJson" />

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary" onclick="serializeCustomFields()">
          <i class="bi bi-save me-1"></i>Save Changes
        </button>
        <a href="/books/<%= book._id %>" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

<script>
function addCustomField() {
  const container = document.getElementById('customFieldsContainer');
  const div = document.createElement('div');
  div.className = 'row g-2 mb-2 custom-field-row';
  div.innerHTML = `
    <div class="col-5"><input type="text" class="form-control form-control-sm cf-name" placeholder="Field Name" /></div>
    <div class="col-3"><select class="form-select form-select-sm cf-type"><option value="text">Text</option><option value="number">Number</option><option value="date">Date</option><option value="boolean">Yes/No</option></select></div>
    <div class="col-3"><input type="text" class="form-control form-control-sm cf-value" placeholder="Value" /></div>
    <div class="col-1"><button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('.custom-field-row').remove()"><i class="bi bi-trash"></i></button></div>`;
  container.appendChild(div);
}
function serializeCustomFields() {
  const rows = document.querySelectorAll('.custom-field-row');
  const fields = [];
  rows.forEach(row => {
    const name  = row.querySelector('.cf-name').value.trim();
    const type  = row.querySelector('.cf-type').value;
    const value = row.querySelector('.cf-value').value.trim();
    if (name) fields.push({ fieldName: name, fieldType: type, fieldValue: value });
  });
  document.getElementById('customFieldsJson').value = JSON.stringify(fields);
}
</script>
