<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-people me-2 text-success"></i><%= t('customers.title') %></h2>
  <div class="d-flex gap-2">
    <a href="/customers/add" class="btn btn-success"><i class="bi bi-person-plus me-1"></i><%= t('customers.addCustomer') %></a>
    <button class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#importModal">
      <i class="bi bi-file-earmark-excel me-1"></i>Import Excel
    </button>
  </div>
</div>

<!-- Search -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form class="row g-2" method="GET" action="/customers">
      <div class="col-md-10">
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input type="text" name="q" class="form-control" placeholder="Search by name, email or mobile..."
                 value="<%= query || '' %>" />
        </div>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-success w-100"><i class="bi bi-search me-1"></i>Search</button>
      </div>
    </form>
  </div>
</div>

<p class="text-muted small mb-3">Showing <%= customers.length %> of <%= pagination.total %> members</p>

<% if (customers.length === 0) { %>
<div class="text-center py-5 text-muted">
  <i class="bi bi-person-x display-4"></i>
  <p class="mt-2"><%= t('customers.noCustomers') %></p>
</div>
<% } else { %>
<div class="row g-3 mb-4">
  <% customers.forEach(c => { %>
  <div class="col-md-6 col-lg-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center mb-3">
          <div class="avatar-circle me-3"><%= c.name.charAt(0).toUpperCase() %></div>
          <div>
            <h6 class="fw-bold mb-0"><%= c.name %></h6>
            <small class="text-muted"><%= c.email %></small>
          </div>
          <% if (!c.isActive) { %>
            <span class="badge bg-danger ms-auto">Inactive</span>
          <% } %>
        </div>
        <div class="row g-1 small text-muted">
          <div class="col-6"><i class="bi bi-phone me-1"></i><%= c.mobile %></div>
          <div class="col-6"><i class="bi bi-geo-alt me-1"></i><%= c.address?.city || '—' %></div>
          <div class="col-6"><i class="bi bi-calendar me-1"></i><%= new Date(c.membershipDate).toLocaleDateString('en-IN') %></div>
          <div class="col-6"><i class="bi bi-currency-rupee me-1"></i>₹<%= c.monthlyFee %>/mo</div>
        </div>
        <div class="mt-2">
          <span class="badge bg-light text-dark border"><%= c.totalBorrowed %> books borrowed</span>
        </div>
      </div>
      <div class="card-footer bg-white border-0 d-flex gap-2">
        <a href="/customers/<%= c._id %>" class="btn btn-sm btn-outline-success flex-grow-1"><i class="bi bi-eye me-1"></i>View</a>
        <a href="/customers/<%= c._id %>/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
        <a href="/transactions/checkout?customerId=<%= c._id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-box-arrow-right"></i></a>
      </div>
    </div>
  </div>
  <% }) %>
</div>

<% if (pagination.totalPages > 1) { %>
<nav>
  <ul class="pagination justify-content-center">
    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>&q=<%= query||'' %>"><%= i %></a>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>
<% } %>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Import Customers from Excel</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <a href="/api/template/customers" class="btn btn-sm btn-outline-success mb-3">
          <i class="bi bi-download me-1"></i>Download Template
        </a>
        <form action="/customers/import" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">Select Excel File (.xlsx)</label>
            <input type="file" name="excelFile" class="form-control" accept=".xlsx,.xls" required />
          </div>
          <button type="submit" class="btn btn-success w-100">Import</button>
        </form>
      </div>
    </div>
  </div>
</div>
